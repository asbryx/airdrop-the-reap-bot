# Copy to .env for safer local auth instead of committing config.json
# Single-account mode:
REAP_ACCESS_TOKEN=
REAP_REFRESH_TOKEN=
REAP_USER_ID=
REAP_TOKEN_TYPE=bearer
REAP_EXPIRES_IN=3600
REAP_EXPIRES_AT=0

# Optional: provide a full user JSON object instead of REAP_USER_ID
# REAP_USER_JSON={"id":"your-user-id"}

# Optional: multi-account mode as JSON array; overrides single-account env auth
# REAP_ACCOUNTS_JSON=[{"name":"Main","auth":{"access_token":"...","refresh_token":"...","expires_at":0,"user":{"id":"..."}}}]

# Optional settings overrides
# REAP_AUTO_JOIN_ROUNDS=false
# REAP_JOIN_BALANCE_THRESHOLD=5000
# REAP_ROUND_JOIN_STRATEGY=random
# REAP_ROUND_JOIN_CHANCE=0.3
# REAP_ROUND_JOIN_MAX_PER_DAY=8
# REAP_JITTER_PERCENT=35
# REAP_ENABLE_RANDOM_IDLE=true
# REAP_ROTATE_USER_AGENT=true
# REAP_MAX_SPECTATE_BONUS_PER_DAY=10
# REAP_SHOW_DASHBOARD_EVERY=10
# REAP_ACCOUNT_DELAY_MS=3000
